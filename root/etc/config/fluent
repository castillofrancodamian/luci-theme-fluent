config global
	# Theme Mode: auto (follow system), light, dark
	option mode 'auto'
	
	# Accent and progress-bar label colors
	option primary '#0078D4'
	option dark_primary '#4da6ff'
	option progressbar_font '#2e2b60'
	option dark_progressbar_font '#d6d9e5'
	# Font Settings
	option font_weight '400'
	option font_size '14'
	
	# Border Radius: 2, 4, 8, 12
	option border_radius '4'
	
	# Control Height: 32, 42
	option control_height '32'
	
	# Sidebar Settings
	option sidebar_width '260'
	option sidebar_style 'default'
	option sidebar_icons '1'
	option sidebar_bg '#f3f3f3'
	
	# Header Settings
	option header_height '48'
	option header_style 'default'
	
	# Login Page Settings
	option login_bg 'microsoft'
	option blur '40'
	option transparency '0.8'
	option blur_dark '20'
	option transparency_dark '0.8'
	option login_animation '1'
	
	# Card Settings
	option card_shadow 'small'
	option card_border '1'
	
	# Transition Settings
	option transition_speed 'normal'
	
	# Advanced Settings
	option custom_css ''
	option dark_sidebar_bg ''
	option dark_card_bg ''
	option dark_page_bg ''
