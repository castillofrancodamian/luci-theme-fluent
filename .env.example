# ============================================================
# LuCI Theme Development - Remote Deploy Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored - never commit your credentials
# ============================================================

# SSH Connection (required)
SSH_HOST=192.168.1.1
SSH_USERNAME=root
SSH_PORT=22

# Authentication (one of these is required)
SSH_PASSWORD=your_password_here
# SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa
# SSH_PASSPHRASE=

SSH_REMOTE_PATH=/www/luci-static/fluent,/www/luci-static/resources,/usr/share/ucode/luci/template/themes/fluent,/etc/config,/etc/uci-defaults,/usr/libexec/rpcd,/usr/share/luci/menu.d,/usr/share/rpcd/acl.d

# Local dist path (optional, defaults to ./htdocs/luci-static/fluent)
LOCAL_DIST_PATH=./htdocs/luci-static/fluent,./htdocs/luci-static/resources,./ucode/template/themes/fluent,./root/etc/config,./root/etc/uci-defaults,./root/usr/libexec/rpcd,./root/usr/share/luci/menu.d,./root/usr/share/rpcd/acl.d

# File extensions to watch/upload (optional, comma-separated)
# UPLOAD_EXTENSIONS=.css,.js,.ut

# Build command (required for dev mode)
BUILD_COMMAND=pnpm run watch

# ============================================================
# Translation (luci-types i18n) Configuration
# ============================================================
# Required for pnpm run i18n:export (AI-powered translation)
# Copy this section to .env and fill in your API key:
#
# Usage:
#   pnpm run i18n:export    # uses dotenvx to load .env automatically
#
# ============================================================
OPENAI_API_KEY=

# Optional: Override the API base URL for custom/local providers
# Default: https://api.openai.com/v1
# OPENAI_API_URL=

# Optional: Override the model used (Default: gpt-4o-mini)
# OPENAI_MODEL=
